# ===============================
# Python cache
# ===============================
__pycache__/
*.py[cod]
*$py.class

# ===============================
# Virtual environments
# ===============================
.venv/
venv/
env/
ENV/

# ===============================
# Jupyter
# ===============================
.ipynb_checkpoints/

# ===============================
# OS files
# ===============================
.DS_Store
Thumbs.db

# ===============================
# Python build artifacts
# ===============================
build/
dist/
*.egg-info/
.eggs/

# ===============================
# Logs
# ===============================
*.log

# ===============================
# Environment variables
# ===============================
.env
.env.*

# ===============================
# IDE settings
# ===============================
.vscode/
.idea/

# ===============================
# Large datasets (do not commit)
# ===============================
data/*.csv
data/*.tsv
data/*.parquet

# Keep data directory but ignore contents
!data/.gitkeep

# ===============================
# Temporary files
# ===============================
*.tmp
*.temp

# ===============================
# PyMC / PyTensor cache
# ===============================
.pytensor/
.pymc/

# ===============================
# Matplotlib cache
# ===============================
.matplotlib/
